# Optional live-data settings. The app runs with deterministic demo data when
# credentials are missing or when an external API is unavailable.
EIA_API_KEY=
NWS_USER_AGENT="ERCOT Grid Pulse Demo (local development)"
NOAA_WEATHER_STREAM_INTERVAL_SECONDS=60
ERCOT_API_SUBSCRIPTION_KEY=
ERCOT_API_SECONDARY_SUBSCRIPTION_KEY=
ERCOT_STREAM_INTERVAL_SECONDS=30
ERCOT_PUBLIC_API_REQUESTS_PER_MINUTE=30
ERCOT_PUBLIC_API_RATE_CUSHION_MS=150
ERCOT_CACHE_SECONDS=60
ERCOT_REPORT_CACHE_SECONDS=60
ERCOT_PRICE_CACHE_SECONDS=180
ERCOT_PRICE_STALE_SECONDS=1800
ERCOT_GRID_SOURCE_CACHE_SECONDS=60
ERCOT_MARKET_SOURCE_CACHE_SECONDS=60
ERCOT_DASHBOARDS_SOURCE_CACHE_SECONDS=60
ERCOT_RT_LMP_POINTS=36
ERCOT_RT_LMP_REFRESH_SECONDS=300
ERCOT_RT_LMP_INITIAL_POINTS=300
ERCOT_RT_LMP_UPDATE_POINTS=12
ERCOT_RT_LMP_MAX_POINTS=288

# ERCOT Public API requires both a subscription key and a bearer token.
# Provide either a currently valid token, or username/password so the app can
# mint and cache an hourly token from ERCOT B2C.
ERCOT_API_ID_TOKEN=
ERCOT_API_USERNAME=
ERCOT_API_PASSWORD=

# Supported aliases:
# NOAA_USER_AGENT=...
# ERCOT_BEARER_TOKEN=...
# ERCOT_USERNAME=...
# ERCOT_PASSWORD=...
